from flask import Flask, render_template, request, jsonify
import pandas as pd
import os

app = Flask(__name__)

# تحميل ملف الإكسل الذي يحتوي على بياناتك كاملة
def load_data():
    if os.path.exists('classification.xlsx'):
        return pd.read_excel('classification.xlsx')
    else:
        # بيانات احتياطية في حال عدم وجود الملف
        return pd.DataFrame(columns=['LCC', 'LCC_Caption', 'DDC', 'DDC_Caption'])

@app.route('/')
def index():
    return render_template('index.html')

@app.route('/search', methods=['POST'])
def search():
    df = load_data()
    data = request.json
    query = str(data.get('query', '')).strip().upper()
    column = data.get('column') # 'LCC' or 'DDC'
    mode = data.get('mode') # 'starts' or 'contains'

    if mode == 'starts':
        results = df[df[column].astype(str).str.upper().str.startswith(query)]
    else:
        results = df[df[column].astype(str).str.upper().str.contains(query)]

    return jsonify(results.to_dict(orient='records'))

if __name__ == '__main__':
    app.run(debug=True)

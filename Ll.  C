// وظيفة تحويل البيانات إلى صيغة MARC
function convertToMARC() {
    const title = document.getElementById('title').value;
    const author = document.getElementById('author').value;
    const isbn = document.getElementById('isbn').value;

    // صياغة مارك مبسطة
    let marcResult = `LDR 00000nam a2200000 u 4500\n`;
    marcResult += `020 $a ${isbn}\n`;
    marcResult += `100 1# $a ${author}\n`;
    marcResult += `245 10 $a ${title}`;

    document.getElementById('marcOutput').innerText = marcResult;
}

// وظيفة تصدير البطاقة كملف نصي
function exportCard() {
    const content = document.getElementById('marcOutput').innerText;
    const blob = new Blob([content], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'catalog_card.txt';
    a.click();
}

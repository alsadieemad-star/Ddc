from flask import Flask, render_template, request, jsonify, send_file
import pandas as pd
import io

app = Flask(__name__)

# --- قاعدة بيانات التصنيف المرسلة من قبلك ---
CLASSIFICATION_DATA = [
    {"lcc": "AC", "lcc_desc": "Collections. Series. Collected works", "ddc": "081-089", "ddc_desc": "General collections"},
    {"lcc": "AE", "lcc_desc": "Encyclopedias", "ddc": "031-039", "ddc_desc": "Encyclopedias & books of facts"},
    {"lcc": "AG", "lcc_desc": "Dictionaries and other general reference works", "ddc": "030", "ddc_desc": "Encyclopedias & books of facts"},
    {"lcc": "AI", "lcc_desc": "Newspapers--Indexes", "ddc": "071-079", "ddc_desc": "Journalism & newspapers"},
    {"lcc": "AM", "lcc_desc": "Museums. Collectors and collecting", "ddc": "069", "ddc_desc": "Associations & museums"},
    {"lcc": "AN", "lcc_desc": "Newspapers", "ddc": "071-079", "ddc_desc": "Journalism & newspapers"},
    {"lcc": "AZ", "lcc_desc": "History of scholarship and learning", "ddc": "001.3", "ddc_desc": "Humanities"},
    {"lcc": "B", "lcc_desc": "Philosophy", "ddc": "100-109", "ddc_desc": "Philosophy"},
    {"lcc": "BC", "lcc_desc": "Logic", "ddc": "160", "ddc_desc": "Logic"},
    {"lcc": "BF", "lcc_desc": "Psychology", "ddc": "150", "ddc_desc": "Psychology"},
    {"lcc": "BJ", "lcc_desc": "Ethics", "ddc": "170", "ddc_desc": "Ethics"},
    {"lcc": "BL", "lcc_desc": "Religions. Mythology", "ddc": "200", "ddc_desc": "Religion"},
    {"lcc": "BP", "lcc_desc": "Islam. Bahaism. Theosophy", "ddc": "297", "ddc_desc": "Islam, Babism, Bahai Faith"},
    {"lcc": "BQ", "lcc_desc": "Buddhism", "ddc": "294.3", "ddc_desc": "Buddhism"},
    {"lcc": "BR", "lcc_desc": "Christianity", "ddc": "230", "ddc_desc": "Christianity"},
    {"lcc": "E", "lcc_desc": "America / United States", "ddc": "973", "ddc_desc": "United States History"}
]

library_store = []

@app.route('/')
def home():
    return render_template('index.html')

@app.route('/process', methods=['POST'])
def process():
    data = request.json
    lcc_input = data.get('lcc', '').upper().strip()
    
    # البحث عن المطابقة في ملف التصنيف
    match = next((item for item in CLASSIFICATION_DATA if lcc_input.startswith(item['lcc'])), None)
    
    ddc_val = match['ddc'] if match else "غير مصنف"
    lcc_caption = match['lcc_desc'] if match else "غير معروف"
    
    # صياغة بطاقة مارك 21 الأكاديمية
    marc_card = (
        f"LDR 00000nam a2200000 u 4500\n"
        f"020 ## $a {data.get('isbn')}\n"
        f"050 00 $a {lcc_input} $b .Mapping\n"
        f"082 00 $a {ddc_val} $2 23\n"
        f"100 1# $a {data.get('author')}\n"
        f"245 10 $a {data.get('title')} / $c {data.get('author')}"
    )

    entry = {
        "title": data.get('title'),
        "author": data.get('author'),
        "isbn": data.get('isbn'),
        "lcc": lcc_input,
        "ddc": ddc_val,
        "caption": lcc_caption,
        "marc": marc_card
    }
    library_store.append(entry)
    return jsonify(entry)

@app.route('/export')
def export():
    if not library_store: return "القائمة فارغة"
    df = pd.DataFrame(library_store)
    output = io.BytesIO()
    with pd.ExcelWriter(output, engine='openpyxl') as writer:
        df.to_excel(writer, index=False)
    output.seek(0)
    return send_file(output, as_attachment=True, download_name="Catalog_Report.xlsx")

if __name__ == '__main__':
    app.run(debug=True)
